# Aztec Web Boilerplate - Environment Variables
# Copy this file to .env and modify as needed

# ═══════════════════════════════════════════════════════════════
# OPTIONAL OVERRIDES
# These override the default values from config/deployments/*.json
# ═══════════════════════════════════════════════════════════════

# Override the Aztec node URL (default: http://localhost:8080 for sandbox)
# VITE_AZTEC_NODE_URL=http://localhost:8080

# Disable prover for faster development (default: false for sandbox, true for testnet)
# VITE_PROVER_ENABLED=false

# ═══════════════════════════════════════════════════════════════
# DEPLOYMENT SCRIPT OVERRIDES
# Used when running yarn deploy-contracts
# ═══════════════════════════════════════════════════════════════

# Override the Aztec node URL for deployment
# AZTEC_NODE_URL=http://localhost:8080

# Disable prover during deployment (much faster for development)
# PROVER_ENABLED=false
