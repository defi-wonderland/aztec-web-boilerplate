{
  "compilerOptions": {
    "target": "es2020",
    "outDir": "artifacts/build",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@aztec-wallet": ["packages/aztec-wallet/index.ts"],
      "@aztec-wallet/*": ["packages/aztec-wallet/*"],
      "@contract-registry": ["packages/contract-registry/index.ts"],
      "@contract-registry/*": ["packages/contract-registry/*"],
      "@use-aztec": ["packages/use-aztec/index.ts"],
      "@use-aztec/*": ["packages/use-aztec/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/vite-env.d.ts",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "tests/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
