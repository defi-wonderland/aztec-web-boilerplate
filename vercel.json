{
  "buildCommand": "yarn build-app:ci",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/devnet-status",
      "destination": "https://v4-devnet-2.aztec-labs.com/status"
    },
    {
      "source": "/artifact-registry/:path*",
      "destination": "https://devnet.aztec-registry.xyz/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "credentialless"
        },
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        }
      ]
    }
  ]
}
